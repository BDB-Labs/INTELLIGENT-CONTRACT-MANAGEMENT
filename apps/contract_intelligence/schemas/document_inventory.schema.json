{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DocumentInventory",
  "type": "object",
  "required": ["project_id", "analysis_perspective", "documents", "missing_required_documents"],
  "properties": {
    "project_id": {"type": "string"},
    "analysis_perspective": {"type": "string", "enum": ["vendor", "agency"]},
    "documents": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "document_id",
          "filename",
          "document_type",
          "required_for_bid_review",
          "text_available",
          "text_source",
          "text_quality",
          "clause_count"
        ],
        "properties": {
          "document_id": {"type": "string"},
          "filename": {"type": "string"},
          "document_type": {"type": "string"},
          "required_for_bid_review": {"type": "boolean"},
          "text_available": {"type": "boolean"},
          "text_source": {"type": "string"},
          "text_quality": {"type": "string"},
          "clause_count": {"type": "integer", "minimum": 0}
        }
      }
    },
    "missing_required_documents": {
      "type": "array",
      "items": {"type": "string"}
    }
  }
}
