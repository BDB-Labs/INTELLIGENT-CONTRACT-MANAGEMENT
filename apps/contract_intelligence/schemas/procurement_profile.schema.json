{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ProcurementProfile",
  "type": "object",
  "required": [
    "project_id",
    "agreement_type",
    "project_sector",
    "payment_mechanism",
    "procurement_method",
    "public_text_quality",
    "governance_artifacts_present",
    "detected_clause_families",
    "evidence",
    "notes"
  ],
  "properties": {
    "project_id": {"type": "string"},
    "agreement_type": {"type": "string"},
    "project_sector": {"type": "string"},
    "payment_mechanism": {"type": "string"},
    "procurement_method": {"type": "string"},
    "public_text_quality": {"type": "string"},
    "governance_artifacts_present": {
      "type": "array",
      "items": {"type": "string"}
    },
    "detected_clause_families": {
      "type": "array",
      "items": {"type": "string"}
    },
    "evidence": {
      "type": "array",
      "items": {"$ref": "#/$defs/evidenceRef"}
    },
    "notes": {
      "type": "array",
      "items": {"type": "string"}
    }
  },
  "$defs": {
    "evidenceRef": {
      "type": "object",
      "required": ["document_id", "location"],
      "properties": {
        "document_id": {"type": "string"},
        "location": {"type": "string"},
        "excerpt": {"type": ["string", "null"]}
      }
    }
  }
}
