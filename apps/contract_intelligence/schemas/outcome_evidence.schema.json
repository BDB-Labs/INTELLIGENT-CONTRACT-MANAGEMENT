{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OutcomeEvidenceBundle",
  "type": "object",
  "required": [
    "project_id",
    "outcome_status",
    "governance_artifacts_present",
    "events",
    "coverage_gaps",
    "monitoring_recommendations"
  ],
  "properties": {
    "project_id": {"type": "string"},
    "outcome_status": {"type": "string"},
    "governance_artifacts_present": {
      "type": "array",
      "items": {"type": "string"}
    },
    "events": {
      "type": "array",
      "items": {"$ref": "#/$defs/outcomeEvent"}
    },
    "coverage_gaps": {
      "type": "array",
      "items": {"type": "string"}
    },
    "monitoring_recommendations": {
      "type": "array",
      "items": {"type": "string"}
    }
  },
  "$defs": {
    "evidenceRef": {
      "type": "object",
      "required": ["document_id", "location"],
      "properties": {
        "document_id": {"type": "string"},
        "location": {"type": "string"},
        "excerpt": {"type": ["string", "null"]}
      }
    },
    "outcomeEvent": {
      "type": "object",
      "required": [
        "event_type",
        "impact_types",
        "summary",
        "confidence",
        "source_document_type",
        "evidence_source_type",
        "evidence"
      ],
      "properties": {
        "event_type": {"type": "string"},
        "impact_types": {
          "type": "array",
          "items": {"type": "string"}
        },
        "summary": {"type": "string"},
        "confidence": {"type": "number", "minimum": 0.0, "maximum": 1.0},
        "source_document_type": {"type": "string"},
        "evidence_source_type": {"type": "string"},
        "evidence": {
          "type": "array",
          "items": {"$ref": "#/$defs/evidenceRef"}
        }
      }
    }
  }
}
