{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Negotiation Strategy Schema",
  "type": "object",
  "required": ["overall_approach", "priority_matrix", "phase_roadmap", "trade_off_analysis", "next_steps"],
  "properties": {
    "overall_approach": {
      "type": "string",
      "enum": ["collaborative", "competitive", "compromising", "avoiding"]
    },
    "priority_matrix": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["issue", "technical_risk", "relationship_impact", "priority_score", "recommended_action"],
        "properties": {
          "issue": {"type": "string"},
          "technical_risk": {"type": "string", "enum": ["low", "medium", "high", "critical"]},
          "relationship_impact": {"type": "string", "enum": ["very_negative", "negative", "neutral", "positive", "very_positive"]},
          "priority_score": {"type": "number", "minimum": 1, "maximum": 10},
          "recommended_action": {"type": "string", "enum": ["hold_firm", "seek_concession", "creative_solution", "accept_as_is", "walk_away"]},
          "negotiation_effort": {"type": "string", "enum": ["high", "medium", "low"]},
          "trading_value": {"type": "string"}
        }
      }
    },
    "phase_roadmap": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["phase", "timing", "focus_areas", "objectives", "success_criteria"],
        "properties": {
          "phase": {"type": "string", "enum": ["pre_bid", "bid_submission", "negotiation", "post_award"]},
          "timing": {"type": "string"},
          "focus_areas": {"type": "array", "items": {"type": "string"}},
          "objectives": {"type": "array", "items": {"type": "string"}},
          "success_criteria": {"type": "array", "items": {"type": "string"}},
          "key_stakeholders": {"type": "array", "items": {"type": "string"}},
          "preparation_requirements": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "trade_off_analysis": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["what_you_gain", "what_you_give_up", "relationship_cost", "risk_reduction", "net_value"],
        "properties": {
          "what_you_gain": {"type": "string"},
          "what_you_give_up": {"type": "string"},
          "relationship_cost": {"type": "number", "minimum": -5, "maximum": 5},
          "risk_reduction": {"type": "number", "minimum": 0, "maximum": 10},
          "net_value": {"type": "string", "enum": ["strongly_negative", "negative", "neutral", "positive", "strongly_positive"]},
          "alternative_if_rejected": {"type": "string"}
        }
      }
    },
    "next_steps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["action", "owner", "timeline", "dependencies", "success_metric"],
        "properties": {
          "action": {"type": "string"},
          "owner": {"type": "string"},
          "timeline": {"type": "string"},
          "dependencies": {"type": "array", "items": {"type": "string"}},
          "success_metric": {"type": "string"},
          "escalation_path": {"type": "string"}
        }
      }
    },
    "executive_summary": {"type": "string"},
    "confidence": {"type": "string", "enum": ["low", "medium", "high"]},
    "relationship_alignment_score": {"type": "number", "minimum": 0, "maximum": 10}
  }
}
