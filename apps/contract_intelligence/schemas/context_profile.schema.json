{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ContextProfile",
  "type": "object",
  "required": [
    "project_id",
    "funding_flexibility",
    "schedule_pressure",
    "oversight_intensity",
    "public_visibility",
    "internal_only",
    "signals",
    "notes"
  ],
  "properties": {
    "project_id": {"type": "string"},
    "funding_flexibility": {"type": "string"},
    "schedule_pressure": {"type": "string"},
    "oversight_intensity": {"type": "string"},
    "public_visibility": {"type": "string"},
    "internal_only": {"type": "boolean"},
    "signals": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["signal_type", "intensity", "summary", "internal_only", "evidence"],
        "properties": {
          "signal_type": {"type": "string"},
          "intensity": {"type": "string"},
          "summary": {"type": "string"},
          "internal_only": {"type": "boolean"},
          "evidence": {
            "type": "array",
            "items": {"$ref": "#/$defs/evidenceRef"}
          }
        }
      }
    },
    "notes": {
      "type": "array",
      "items": {"type": "string"}
    }
  },
  "$defs": {
    "evidenceRef": {
      "type": "object",
      "required": ["document_id", "location"],
      "properties": {
        "document_id": {"type": "string"},
        "location": {"type": "string"},
        "excerpt": {"type": ["string", "null"]}
      }
    }
  }
}
