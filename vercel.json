{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    },
    {
      "source": "/generated/manifest.json",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/", "destination": "/demo_site/index.html" },
    { "source": "/index.html", "destination": "/demo_site/index.html" },
    { "source": "/app.js", "destination": "/demo_site/app.js" },
    { "source": "/styles.css", "destination": "/demo_site/styles.css" },
    { "source": "/generated/:path*", "destination": "/demo_site/generated/:path*" },
    { "source": "/cases/:path*", "destination": "/demo_site/generated/cases/:path*" }
  ]
}
